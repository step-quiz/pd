# Canvia poc → caché llarg
/assets/lib/*
  Cache-Control: public, max-age=31536000, immutable

/assets/css/*
  Cache-Control: public, max-age=86400

/assets/js/*
  Cache-Control: public, max-age=86400

# Canvia sovint → sense caché
/seguiment-link.txt
  Cache-Control: no-store

/contingut/*/pdfs/manifest.json
  Cache-Control: no-store

/contingut/*/course.json
  Cache-Control: no-store

# Fitxers de contingut → caché curt
/contingut/*
  Cache-Control: public, max-age=3600

# Fonts LaTeX: al repo però no indexables
/contingut/*/source/*
  X-Robots-Tag: noindex
